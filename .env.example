# Copy to .env and fill in. GEMINI_API_KEY is required for answer generation.
GEMINI_API_KEY=AIza...

# Qdrant (docker-compose sets this to http://qdrant:6333 automatically)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Optional overrides
# LLM_MODEL=gemini-2.5-flash
# COLLECTION_NAME=rag_chunks
# TOP_K=5
